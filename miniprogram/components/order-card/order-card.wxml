<!--components/order-card/order-card.wxml-->
<view class="order-card" bindtap="onTap">
  <view class="order-route">
    <text class="route-icon">📍</text>
    <text class="route-text">{{order.startLocation.name}} → {{order.endLocation.name}}</text>
  </view>

  <view class="order-info">
    <view class="info-item">
      <text class="info-icon">🕐</text>
      <text class="info-text">{{order.appointmentTimeDisplay}}</text>
    </view>
    <view class="info-item">
      <text class="info-icon">👤</text>
      <text class="info-text">{{order.passengerCount}}人</text>
    </view>
  </view>

  <view class="order-remark" wx:if="{{order.remark}}">
    <text class="remark-icon">📝</text>
    <text class="remark-text">{{order.remark}}</text>
  </view>

  <view class="order-footer">
    <view class="status-tag {{order.statusClass}}">{{order.statusText}}</view>
    <view class="order-meta">
      <text class="meta-text">ID: {{order.id}}</text>
      <text class="arrow-icon">→</text>
    </view>
  </view>
</view>
