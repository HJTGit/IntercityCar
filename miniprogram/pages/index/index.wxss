/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  background: var(--background);
  padding: var(--spacing-lg);
}

/* Logo 区域 */
.logo-section {
  text-align: center;
  padding: 60px 0 40px;
}

.logo-icon {
  font-size: 64px;
  margin-bottom: 16px;
}

.logo-text {
  font-size: 24px;
  font-weight: 600;
  color: var(--text-primary);
}

/* 功能入口 */
.action-section {
  margin-bottom: var(--spacing-lg);
}

.action-card {
  display: flex;
  align-items: center;
  padding: 20px;
  background: var(--background-white);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  margin-bottom: var(--spacing-md);
}

.action-icon {
  font-size: 32px;
  margin-right: 16px;
}

.action-content {
  flex: 1;
}

.action-title {
  font-size: 16px;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.action-desc {
  font-size: 13px;
  color: var(--text-secondary);
}

.action-arrow {
  font-size: 18px;
  color: var(--text-placeholder);
}

/* TabBar 占位 */
.tab-bar-placeholder {
  height: 56px;
}

/* 登录弹窗 */
.login-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.login-content {
  position: relative;
  width: 320px;
  background: var(--background-white);
  border-radius: var(--radius-lg);
  padding: 32px 24px;
  margin: 0 auto;
}

.login-header {
  text-align: center;
  margin-bottom: 24px;
}

.login-title {
  font-size: 20px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8px;
}

.login-subtitle {
  font-size: 14px;
  color: var(--text-secondary);
}

.login-item {
  margin-bottom: 20px;
}

.login-label {
  font-size: 14px;
  color: var(--text-primary);
  margin-bottom: 8px;
  font-weight: 500;
}

.login-input {
  width: 100%;
  height: 44px;
  padding: 0 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  font-size: 14px;
  box-sizing: border-box;
}

.avatar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: var(--background);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
}

.avatar-img image {
  width: 80px;
  height: 80px;
  border-radius: 50%;
}

.avatar-tip {
  font-size: 12px;
  color: var(--text-secondary);
  margin-top: 8px;
}

.login-btn {
  width: 100%;
  margin-top: 12px;
}
