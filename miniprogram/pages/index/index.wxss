/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  background: var(--background);
  padding: var(--spacing-lg);
}

/* Logo 区域 */
.logo-section {
  text-align: center;
  padding: 60px 0 40px;
}

.logo-icon {
  font-size: 64px;
  margin-bottom: 16px;
}

.logo-text {
  font-size: 24px;
  font-weight: 600;
  color: var(--text-primary);
}

/* 功能入口 */
.action-section {
  margin-bottom: var(--spacing-lg);
}

.action-card {
  display: flex;
  align-items: center;
  padding: 20px;
  background: var(--background-white);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  margin-bottom: var(--spacing-md);
}

.action-icon {
  font-size: 32px;
  margin-right: 16px;
}

.action-content {
  flex: 1;
}

.action-title {
  font-size: 16px;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.action-desc {
  font-size: 13px;
  color: var(--text-secondary);
}

.action-arrow {
  font-size: 18px;
  color: var(--text-placeholder);
}

/* TabBar 占位 */
.tab-bar-placeholder {
  height: 56px;
}
