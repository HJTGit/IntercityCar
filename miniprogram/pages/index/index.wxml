<!--pages/index/index.wxml-->
<view class="container">
  <!-- Logo 区域 -->
  <view class="logo-section">
    <view class="logo-icon">🚗</view>
    <view class="logo-text">上门车接车送</view>
  </view>

  <!-- 功能入口 -->
  <view class="action-section">
    <view class="action-card card" bindtap="onGoCreateOrder">
      <view class="action-icon">🚗</view>
      <view class="action-content">
        <view class="action-title">立即叫车</view>
        <view class="action-desc">预约上门接送</view>
      </view>
      <view class="action-arrow">→</view>
    </view>

    <view class="action-card card" bindtap="onGoOrderList">
      <view class="action-icon">📋</view>
      <view class="action-content">
        <view class="action-title">我的订单</view>
        <view class="action-desc">查看历史订单</view>
      </view>
      <view class="action-arrow">→</view>
    </view>
  </view>

  <!-- 底部 TabBar 占位 -->
  <view class="tab-bar-placeholder"></view>
</view>

<!-- 登录弹窗 -->
<view class="login-modal" wx:if="{{showLogin}}">
  <view class="login-mask"></view>
  <view class="login-content">
    <view class="login-header">
      <view class="login-title">欢迎使用</view>
      <view class="login-subtitle">请完善您的信息</view>
    </view>

    <!-- 头像选择 -->
    <view class="login-item">
      <view class="login-label">头像</view>
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <view class="avatar-img">
          <image wx:if="{{loginData.avatar}}" src="{{loginData.avatar}}" mode="aspectFill"></image>
          <text wx:else>👤</text>
        </view>
        <view class="avatar-tip">点击选择</view>
      </button>
    </view>

    <!-- 昵称输入 -->
    <view class="login-item">
      <view class="login-label">昵称</view>
      <input
        type="nickname"
        class="login-input"
        placeholder="请输入昵称"
        bindblur="onNicknameBlur"
        value="{{loginData.nickname}}"
      />
    </view>

    <!-- 手机号输入 -->
    <view class="login-item">
      <view class="login-label">手机号</view>
      <input
        type="number"
        class="login-input"
        placeholder="请输入手机号（选填）"
        maxlength="11"
        bindinput="onPhoneInput"
        value="{{loginData.phone}}"
      />
    </view>

    <!-- 完成按钮 -->
    <button class="btn btn-primary login-btn" bindtap="onLoginComplete">完成注册</button>
  </view>
</view>
