/* pages/order-detail/order-detail.wxss */

.container {
  min-height: 100vh;
  background: var(--background);
  padding: 0 var(--spacing-lg);
  padding-bottom: 100px;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 var(--spacing-lg);
  background: var(--background-white);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-back {
  font-size: 20px;
  color: var(--text-primary);
  padding: 8px;
}

.nav-title {
  font-size: 16px;
  font-weight: 500;
  color: var(--text-primary);
}

.nav-more {
  width: 40px;
}

/* 订单状态区域 */
.order-status-section {
  margin-top: var(--spacing-lg);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-number {
  font-size: 14px;
  color: var(--text-secondary);
}

.status-tag-large {
  display: inline-block;
  padding: 6px 16px;
  border-radius: var(--radius-md);
  font-size: 14px;
  font-weight: 500;
}

.status-tag-large.tag-pending {
  background: var(--tag-pending-bg);
  color: var(--warning);
}

.status-tag-large.tag-accepted {
  background: var(--tag-accepted-bg);
  color: var(--primary);
}

.status-tag-large.tag-completed {
  background: var(--tag-completed-bg);
  color: var(--success);
}

.status-tag-large.tag-cancelled {
  background: var(--tag-cancelled-bg);
  color: var(--text-placeholder);
}

/* 地图区域 */
.map-section {
  padding: 0;
  overflow: hidden;
}

.map-placeholder {
  height: 180px;
  background: linear-gradient(135deg, #e6f7ff 0%, #f5f5f5 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.map-icon {
  font-size: 48px;
  margin-bottom: 8px;
}

.map-text {
  font-size: 14px;
  color: var(--text-secondary);
  margin-bottom: 12px;
}

.map-hint {
  font-size: 13px;
  color: var(--text-secondary);
  margin-bottom: 4px;
}

/* 信息区域 */
.info-section {
  margin-top: var(--spacing-lg);
}

.section-title {
  font-size: 16px;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--spacing-lg);
  padding-bottom: var(--spacing-md);
  border-bottom: 1px solid var(--border);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
}

.info-label {
  font-size: 14px;
  color: var(--text-secondary);
}

.info-value {
  font-size: 14px;
  color: var(--text-primary);
}

.info-value.phone {
  color: var(--primary);
}

.info-divider {
  height: 1px;
  background: var(--border);
}

/* 操作按钮 */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacing-lg);
  background: var(--background-white);
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.08);
}

.action-section .btn {
  width: 100%;
}

/* TabBar 占位 */
.tab-bar-placeholder {
  height: 56px;
}
