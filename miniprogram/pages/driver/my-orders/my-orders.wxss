/* pages/driver/my-orders/my-orders.wxss */

.container {
  min-height: 100vh;
  background: var(--background);
  padding: 0 var(--spacing-lg);
}

/* 页面标题 */
.page-header {
  padding: var(--spacing-lg) 0;
}

.page-title {
  font-size: 24px;
  font-weight: 600;
  color: var(--text-primary);
}

/* 用户信息卡片 */
.user-card {
  margin-bottom: var(--spacing-lg);
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 60px;
  height: 60px;
  background: var(--tag-accepted-bg);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  margin-right: var(--spacing-lg);
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 18px;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.user-role {
  font-size: 14px;
  color: var(--text-secondary);
}

/* 切换卡片 */
.switch-card {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-lg);
  padding: var(--spacing-lg);
}

.switch-icon {
  font-size: 32px;
  margin-right: var(--spacing-lg);
}

.switch-content {
  flex: 1;
}

.switch-title {
  font-size: 16px;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.switch-desc {
  font-size: 13px;
  color: var(--text-secondary);
}

.switch-arrow {
  font-size: 18px;
  color: var(--text-placeholder);
}

/* 状态筛选 */
.status-tabs {
  display: flex;
  gap: var(--spacing-sm);
  padding-bottom: var(--spacing-lg);
}

.status-tab {
  padding: 8px 16px;
  font-size: 14px;
  color: var(--text-secondary);
  background: var(--background-white);
  border-radius: var(--radius-full);
  border: 1px solid var(--border);
}

.status-tab.active {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

/* 订单卡片 */
.order-card {
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
}

.order-route {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.route-icon {
  font-size: 16px;
  margin-right: 8px;
}

.route-text {
  font-size: 16px;
  font-weight: 500;
  color: var(--text-primary);
}

.order-info {
  margin-bottom: 12px;
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 4px;
}

.info-icon {
  font-size: 14px;
  margin-right: 4px;
}

.info-text {
  font-size: 14px;
  color: var(--text-secondary);
  margin-right: 8px;
}

.order-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12px;
  border-top: 1px solid var(--border);
}

.status-tag {
  display: inline-block;
  padding: 4px 12px;
  border-radius: var(--radius-sm);
  font-size: 12px;
  font-weight: 500;
}

.status-tag.tag-pending {
  background: var(--tag-pending-bg);
  color: var(--warning);
}

.status-tag.tag-accepted {
  background: var(--tag-accepted-bg);
  color: var(--primary);
}

.status-tag.tag-completed {
  background: var(--tag-completed-bg);
  color: var(--success);
}

.status-tag.tag-cancelled {
  background: var(--tag-cancelled-bg);
  color: var(--text-placeholder);
}

.order-meta {
  display: flex;
  align-items: center;
}

.arrow-icon {
  font-size: 14px;
  color: var(--text-placeholder);
}

/* 操作按钮 */
.order-actions {
  padding-top: 12px;
}

.complete-btn {
  width: 100%;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 60px 20px;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 14px;
  color: var(--text-placeholder);
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 20px;
  color: var(--text-placeholder);
}

/* TabBar 占位 */
.tab-bar-placeholder {
  height: 56px;
}
