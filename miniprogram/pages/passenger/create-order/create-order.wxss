/* pages/passenger/create-order/create-order.wxss */

.container {
  min-height: 100vh;
  background: var(--background);
  padding: 0 var(--spacing-lg);
  padding-bottom: 100px;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 var(--spacing-lg);
  background: var(--background-white);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-back {
  font-size: 20px;
  color: var(--text-primary);
  padding: 8px;
}

.nav-title {
  font-size: 16px;
  font-weight: 500;
  color: var(--text-primary);
}

.nav-more {
  font-size: 16px;
  color: var(--text-secondary);
  padding: 8px;
}

/* 行程信息卡片 */
.route-card {
  margin-top: var(--spacing-lg);
}

.route-header {
  font-size: 16px;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--spacing-lg);
}

.route-line {
  height: 32px;
  width: 2px;
  background: var(--border);
  margin-left: 12px;
}

.location-item {
  display: flex;
  align-items: flex-start;
  padding: 8px 0;
}

.location-dot {
  font-size: 16px;
  margin-right: 12px;
  margin-top: 2px;
}

.start-dot {
  color: var(--primary);
}

.end-dot {
  color: var(--success);
}

.location-content {
  flex: 1;
}

.location-label {
  font-size: 12px;
  color: var(--text-secondary);
  margin-bottom: 4px;
}

.location-value {
  font-size: 16px;
  color: var(--text-primary);
}

.location-value.placeholder {
  color: var(--text-placeholder);
}

.location-arrow {
  font-size: 20px;
  color: var(--text-placeholder);
  padding: 8px;
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 48px;
}

.form-label {
  font-size: 14px;
  color: var(--text-primary);
  font-weight: 500;
  flex-shrink: 0;
}

/* 日期时间选择器 */
.datetime-picker {
  display: flex;
  align-items: center;
  background: var(--background);
  border-radius: var(--radius-lg);
  padding: 4px;
  margin-top: 8px;
}

.datetime-item {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 12px 8px;
}

.datetime-icon {
  font-size: 18px;
  margin-right: 8px;
}

.datetime-value {
  flex: 1;
  font-size: 15px;
  color: var(--text-primary);
}

.datetime-arrow {
  font-size: 16px;
  color: var(--text-placeholder);
}

.datetime-divider {
  width: 1px;
  height: 32px;
  background: var(--border);
  margin: 0 8px;
}

/* 计数器 */
.counter {
  display: flex;
  align-items: center;
}

.counter-btn {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 500;
}

.counter-btn.disabled {
  background: var(--border);
  color: var(--text-placeholder);
}

.counter-value {
  min-width: 48px;
  text-align: center;
  font-size: 16px;
  font-weight: 500;
  color: var(--text-primary);
}

/* 输入框 */
.input {
  flex: 1;
  height: 40px;
  padding: 0 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  font-size: 14px;
  background: var(--background-white);
  margin-left: 12px;
}

/* 提交区域 */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacing-lg);
  background: var(--background-white);
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.08);
}

.submit-btn {
  width: 100%;
}

/* TabBar 占位 */
.tab-bar-placeholder {
  height: 56px;
}
