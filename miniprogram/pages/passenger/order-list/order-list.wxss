/* pages/passenger/order-list/order-list.wxss */

.container {
  min-height: 100vh;
  background: var(--background);
  padding: 0 var(--spacing-lg);
}

/* 页面标题 */
.page-header {
  padding: var(--spacing-lg) 0;
}

.page-title {
  font-size: 24px;
  font-weight: 600;
  color: var(--text-primary);
}

/* 状态筛选 */
.status-tabs {
  display: flex;
  gap: var(--spacing-sm);
  padding-bottom: var(--spacing-lg);
  overflow-x: auto;
}

.status-tab {
  padding: 8px 16px;
  font-size: 14px;
  color: var(--text-secondary);
  background: var(--background-white);
  border-radius: var(--radius-full);
  white-space: nowrap;
  border: 1px solid var(--border);
}

.status-tab.active {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

/* 订单卡片 */
.order-card {
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
}

.order-route {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.route-icon {
  font-size: 16px;
  margin-right: 8px;
}

.route-text {
  font-size: 16px;
  font-weight: 500;
  color: var(--text-primary);
}

.order-info {
  display: flex;
  gap: var(--spacing-lg);
  margin-bottom: 8px;
}

.info-item {
  display: flex;
  align-items: center;
}

.info-icon {
  font-size: 14px;
  margin-right: 4px;
}

.info-text {
  font-size: 14px;
  color: var(--text-secondary);
}

.order-remark {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.remark-icon {
  font-size: 14px;
  margin-right: 4px;
}

.remark-text {
  font-size: 13px;
  color: var(--text-secondary);
}

.order-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12px;
  border-top: 1px solid var(--border);
}

.status-tag {
  display: inline-block;
  padding: 4px 12px;
  border-radius: var(--radius-sm);
  font-size: 12px;
  font-weight: 500;
}

.status-tag.tag-pending {
  background: var(--tag-pending-bg);
  color: var(--warning);
}

.status-tag.tag-accepted {
  background: var(--tag-accepted-bg);
  color: var(--primary);
}

.status-tag.tag-completed {
  background: var(--tag-completed-bg);
  color: var(--success);
}

.status-tag.tag-cancelled {
  background: var(--tag-cancelled-bg);
  color: var(--text-placeholder);
}

.order-meta {
  display: flex;
  align-items: center;
}

.meta-text {
  font-size: 12px;
  color: var(--text-placeholder);
}

.arrow-icon {
  font-size: 14px;
  color: var(--text-placeholder);
  margin-left: 8px;
}

/* 司机信息 */
.driver-info {
  display: flex;
  align-items: center;
  padding-top: 12px;
  margin-top: 12px;
  border-top: 1px solid var(--border);
}

.driver-icon {
  font-size: 14px;
  margin-right: 8px;
}

.driver-text {
  font-size: 14px;
  color: var(--text-primary);
  margin-right: 8px;
}

.driver-phone {
  font-size: 13px;
  color: var(--text-secondary);
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 60px 20px;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 14px;
  color: var(--text-placeholder);
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 20px;
  color: var(--text-placeholder);
}

/* TabBar 占位 */
.tab-bar-placeholder {
  height: 56px;
}
